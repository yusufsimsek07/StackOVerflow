<?xml version="1.0" encoding="UTF-8" ?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="StackOverflowPU" transaction-type="JTA">
        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
        <jta-data-source>java:app/jdbc/PostgresDS</jta-data-source>
        
        <properties>
            <!-- Production'da create-or-extend yapılmaz, DDL ile manuel eklendiği için none. -->
            <property name="eclipselink.ddl-generation" value="create-or-extend" />
            <property name="eclipselink.logging.level" value="INFO" />
            <property name="eclipselink.weaving" value="static" />
        </properties>
    </persistence-unit>

</persistence>
